{
  "name": "@pa-sap-bridge/database",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "db:generate": "node scripts/run-prisma.cjs generate",
    "db:migrate:dev": "node scripts/run-prisma.cjs migrate dev",
    "db:migrate:deploy": "node scripts/run-prisma.cjs migrate deploy",
    "db:migrate:reset": "node scripts/run-prisma.cjs migrate reset --force",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "node scripts/run-prisma.cjs studio",
    "typecheck": "tsc --noEmit",
    "postinstall": "node scripts/run-prisma.cjs generate"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "prisma": "^6.0.0",
    "tsx": "^4.19.4",
    "typescript": "*"
  }
}
