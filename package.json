{
  "name": "pa-sap-bridge",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,worker,web -c green,yellow,cyan --kill-others-on-fail \"npm run dev -w apps/api\" \"npm run dev -w apps/worker\" \"npm run dev -w apps/web\"",
    "dev:api": "npm run dev -w apps/api",
    "dev:worker": "npm run dev -w apps/worker",
    "dev:web": "npm run dev -w apps/web",
    "start:api": "npm run start -w apps/api",
    "start:worker": "npm run start -w apps/worker",
    "start:web": "npm run preview -w apps/web -- --host 0.0.0.0 --port 4173",
    "start:local": "concurrently -n api,worker,web -c green,yellow,cyan --kill-others-on-fail \"npm run start:api\" \"npm run start:worker\" \"npm run start:web\"",
    "build": "npm run build -w packages/shared && npm run build -w apps/api && npm run build -w apps/worker && npm run build -w apps/web",
    "build:api": "npm run build -w apps/api",
    "build:worker": "npm run build -w apps/worker",
    "build:web": "npm run build -w apps/web",
    "lint": "eslint . --ext .ts,.tsx --ignore-path .gitignore",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\" --ignore-path .gitignore",
    "typecheck": "npm run typecheck -w packages/shared && npm run typecheck -w packages/database && npm run typecheck -w apps/api && npm run typecheck -w apps/worker && npm run typecheck -w apps/web",
    "local:env:check": "tsx scripts/check-env.ts",
    "local:prepare": "npm run local:env:check && npm run db:generate && npm run db:migrate:deploy",
    "local:dev": "npm run local:env:check && npm run dev",
    "local:prod": "npm run local:env:check && npm run build && npm run start:local",
    "local:smoke": "npm run local:env:check && npm run test && npm run build",
    "pm2:start": "pm2 start ecosystem.config.cjs --update-env",
    "pm2:restart": "pm2 restart ecosystem.config.cjs --update-env",
    "pm2:stop": "pm2 delete ecosystem.config.cjs",
    "db:generate": "npm run db:generate -w packages/database",
    "db:migrate": "npm run db:migrate:dev -w packages/database",
    "db:migrate:deploy": "npm run db:migrate:deploy -w packages/database",
    "db:migrate:reset": "npm run db:migrate:reset -w packages/database",
    "db:seed": "npm run db:seed -w packages/database",
    "db:studio": "npm run db:studio -w packages/database",
    "test": "vitest run --config vitest.config.ts",
    "test:unit": "vitest run --config vitest.config.ts tests/unit",
    "test:integration": "vitest run --config vitest.config.ts tests/integration",
    "test:e2e": "vitest run --config vitest.config.ts tests/e2e",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "test:sap-login": "tsx scripts/test-sap-login.ts",
    "test:sap-login:dry": "tsx scripts/test-sap-login.ts --dry-run",
    "seed:fixtures": "tsx scripts/seed-fixtures.ts",
    "ingest:once": "npm run ingest:once -w apps/worker",
    "seed:matching": "tsx scripts/seed-matching.ts",
    "test:matching": "tsx scripts/test-rule-engine.ts",
    "check:lot9": "tsx scripts/check-lot9.ts"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^9.1.0",
    "eslint": "^8.57.1",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
