# ====================================================
# PA-SAP-BRIDGE — Configuration d'environnement
# Copiez ce fichier en .env et renseignez les valeurs
# ====================================================

# ---------------------------------------------------------------------------
# APPLICATION GLOBALE
# ---------------------------------------------------------------------------
NODE_ENV=development
# Niveau de log : trace | debug | info | warn | error | fatal
LOG_LEVEL=info
# Secret de signature du cookie applicatif (32+ caractères en production)
SESSION_COOKIE_SECRET=change-this-cookie-secret-in-production

# ---------------------------------------------------------------------------
# API (apps/api)
# ---------------------------------------------------------------------------
API_PORT=3001
APP_HOST=0.0.0.0
# Origine acceptée par CORS (URL du front en développement)
CORS_ORIGIN=http://localhost:5173

# ---------------------------------------------------------------------------
# WORKER (apps/worker)
# ---------------------------------------------------------------------------
# Intervalle entre chaque cycle de traitement (millisecondes)
WORKER_POLL_INTERVAL_MS=30000
# Répertoire de sortie des statuts PA simulés (optionnel)
# Par défaut : <FILE_STORAGE_PATH>\status-out
STATUS_OUT_PATH=
# Politique de retries PA (optionnel)
PA_STATUS_MAX_RETRIES=3
PA_STATUS_RETRY_DELAYS_MS=0,60000,300000

# ---------------------------------------------------------------------------
# BASE DE DONNÉES PostgreSQL
# ---------------------------------------------------------------------------
# URL complète (prioritaire sur les variables individuelles)
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/pa_sap_bridge
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pa_sap_bridge
DB_USER=postgres
DB_PASSWORD=changeme

# ---------------------------------------------------------------------------
# SAP BUSINESS ONE — Service Layer REST
# ---------------------------------------------------------------------------
SAP_REST_BASE_URL=https://YOUR_SAP_HOST:50000/b1s/v1
SAP_USER=manager
# Nom de la base de données de la société SAP
SAP_CLIENT=YOUR_COMPANY_DB
SAP_CLIENT_PASSWORD=changeme
SAP_LANG=FR
# Société SAP secondaire optionnelle
SAP_CLIENT_RONDOT=
SAP_USER_RONDOT=
SAP_CLIENT_PASSWORD_RONDOT=
# Développement uniquement : bypass certificat auto-signé SAP
SAP_IGNORE_SSL=false
# Politique de validation / post SAP
# SAP_VALIDATION_MODE : live
SAP_VALIDATION_MODE=live
# SAP_ATTACHMENT_POLICY : strict | warn | skip
SAP_ATTACHMENT_POLICY=strict
# SAP_POST_POLICY : real | simulate | disabled
SAP_POST_POLICY=real
# Surcharge optionnelle des ressources SAP Service Layer pour les contrôles live
SAP_BP_RESOURCE=BusinessPartners
SAP_BP_KEY_FIELD=CardCode
SAP_GL_RESOURCE=ChartOfAccounts
SAP_GL_KEY_FIELD=Code
SAP_TAX_RESOURCE=SalesTaxCodes
SAP_TAX_KEY_FIELD=Code
SAP_COST_CENTER_RESOURCE=ProfitCenters
SAP_COST_CENTER_KEY_FIELD=CenterCode

# ---------------------------------------------------------------------------
# PLATEFORME AGRÉÉE (PDP / PPF)
# À compléter selon la PDP choisie
# ---------------------------------------------------------------------------
PDP_API_URL=https://api.votre-pdp.fr
PDP_API_KEY=changeme
# SIREN de la société émettrice
PDP_SIREN=000000000
# Timeout des appels PDP (millisecondes)
PDP_TIMEOUT_MS=10000

# ---------------------------------------------------------------------------
# STOCKAGE FICHIERS LOCAL (Windows)
# Chemin absolu — utiliser des antislashs ou des slashs
# Exemple Windows : C:\ProgramData\pa-sap-bridge\files
# ---------------------------------------------------------------------------
FILE_STORAGE_PATH=C:\ProgramData\pa-sap-bridge\files
